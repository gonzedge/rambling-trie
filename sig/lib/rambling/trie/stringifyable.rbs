module Rambling
  module Trie
    module Stringifyable[TValue < BasicObject & _Inspect & _Nilable]
      def as_word: -> String

      def to_s: -> String

      def collect_letters: (Array[String]) -> void

      private

      # abstract methods

      def letter: -> Symbol

      def terminal?: -> bool

      def parent: -> Nodes::Node[TValue]?

      def children_tree: -> Hash[Symbol, Nodes::Node[TValue]]
    end
  end
end
